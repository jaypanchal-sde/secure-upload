{
  "name": "@secure-upload/core",
  "version": "1.0.1",
  "description": "Zero-knowledge encrypted file uploads for Node.js and Express.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },

  "publishConfig": {
    "access": "public"
  },

  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaypanchal-sde/secure-upload.git"
  },

  "homepage": "https://github.com/jaypanchal-sde/secure-upload#readme",

  "bugs": {
    "url": "https://github.com/jaypanchal-sde/secure-upload/issues"
  },

  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },

  "keywords": [
    "upload",
    "file-upload",
    "express",
    "nodejs",
    "typescript",
    "encryption",
    "security",
    "aws-s3",
    "cloudflare-r2",
    "storage"
  ],

  "author": "Jay Panchal",
  "license": "MIT",

  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
    "busboy": "^1.6.0",
    "express": "^5.2.1"
  },

  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.4.0"
  }
}